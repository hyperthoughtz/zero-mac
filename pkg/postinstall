#!/bin/bash
set -e

LOG="/tmp/zero-install.log"
exec > "$LOG" 2>&1

log() { echo "$(date '+%H:%M:%S') $1"; }

SHARE="/usr/local/share/mihomo"
APP="/Applications/Zero.app"

# Ensure log dir
mkdir -p /usr/local/var/log

# Find console user
CONSOLE_USER=$(stat -f "%Su" /dev/console 2>/dev/null || echo "")
[ -z "$CONSOLE_USER" ] || [ "$CONSOLE_USER" = "root" ] && CONSOLE_USER=$(ls -l /dev/console | awk '{print $3}')
USER_HOME=$(dscl . -read "/Users/$CONSOLE_USER" NFSHomeDirectory 2>/dev/null | awk '{print $2}')

if [ -n "$USER_HOME" ]; then
    CONFDIR="$USER_HOME/.config/mihomo"
    mkdir -p "$CONFDIR"

    # Config: create from template if not exists
    if [ ! -f "$CONFDIR/config.yaml" ]; then
        SECRET=$(openssl rand -hex 16)
        sed "s|\${SECRET}|$SECRET|g" "$SHARE/config.yaml.template" > "$CONFDIR/config.yaml"
        log "Created config.yaml"
    fi

    # Web UI: always update
    rm -rf "$CONFDIR/ui"
    cp -r "$SHARE/ui" "$CONFDIR/ui"

    chown -R "$CONSOLE_USER:staff" "$CONFDIR"

    # Add to login items
    su "$CONSOLE_USER" -c "osascript -e 'tell application \"System Events\" to make login item at end with properties {path:\"$APP\", hidden:false}' 2>/dev/null || true"

    # Launch
    su "$CONSOLE_USER" -c "open '$APP'"
    log "Zero.app launched"
fi

log "Installation complete"
exit 0
